<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Nailed by Mbuyi — luxury nail artistry in Eswatini." />
  <title>Nailed by Mbuyi — Nail Artistry</title>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <style>
    :root {
      --bg: #f5efe9;
      --ink: #171313;
      --muted: #6b5d59;
      --wine: #5b1f2e;
      --rose: #d6a4af;
      --line: rgba(23, 19, 19, 0.08);
      --shadow: 0 18px 50px rgba(16, 10, 10, 0.12);
      --radius: 24px;
      --container: 1240px;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    body {
      font-family: "Inter", sans-serif;
      color: var(--ink);
      background:
        radial-gradient(circle at top left, rgba(214, 164, 175, 0.18), transparent 25%),
        radial-gradient(circle at bottom right, rgba(91, 31, 46, 0.12), transparent 24%),
        var(--bg);
      overflow-x: hidden;
    }

    img { display: block; max-width: 100%; }
    a { color: inherit; text-decoration: none; }
    .container { width: min(var(--container), calc(100% - 2.5rem)); margin: 0 auto; }

    .site-header {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 30;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1rem 1.25rem;
      backdrop-filter: blur(14px);
      background: rgba(245, 239, 233, 0.58);
      border-bottom: 1px solid rgba(255,255,255,0.35);
    }

    .brand {
      font-family: "Cormorant Garamond", serif;
      font-size: 1.7rem;
      font-weight: 500;
    }

    .brand span {
      color: var(--wine);
      font-style: italic;
    }

    .desktop-nav {
      display: flex;
      gap: 2rem;
    }

    .desktop-nav a, .header-book {
      font-size: 0.82rem;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: var(--muted);
    }

    .hero {
      position: relative;
      min-height: 100vh;
      display: flex;
      align-items: stretch;
    }

    .hero-media {
      position: absolute;
      inset: 0;
    }

    .hero-image-wrap {
      position: absolute;
      inset: 0;
      overflow: hidden;
    }

    .hero-image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transform: scale(1.08);
      animation: heroZoom 9s ease forwards;
      filter: saturate(1.03) contrast(1.02);
    }

    .hero-gradient {
      position: absolute;
      inset: 0;
      background:
        linear-gradient(90deg, rgba(10, 8, 10, 0.72) 0%, rgba(10, 8, 10, 0.26) 38%, rgba(10, 8, 10, 0.08) 100%),
        linear-gradient(180deg, rgba(10, 8, 10, 0.18) 0%, rgba(10, 8, 10, 0.22) 100%);
    }

    .hero-overlay {
      min-height: 100vh;
      display: grid;
      grid-template-columns: 1.1fr 0.65fr;
      align-items: end;
      gap: 2rem;
      padding-top: 8rem;
      padding-bottom: 3rem;
      position: relative;
      z-index: 2;
    }

    .hero-copy {
      color: #fff8f5;
      max-width: 720px;
      padding-bottom: 2rem;
    }

    .hero-kicker, .section-tag, .featured-meta, .side-label {
      font-size: 0.75rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }

    .hero-kicker, .side-label {
      color: rgba(255,255,255,0.76);
      margin-bottom: 1rem;
    }

    .hero h1, .section-heading h2, .booking-copy h2, .contact-copy h2 {
      font-family: "Cormorant Garamond", serif;
      font-weight: 400;
      line-height: 0.95;
    }

    .hero h1 {
      font-size: clamp(3.7rem, 9vw, 8rem);
      margin-bottom: 1rem;
      letter-spacing: -0.03em;
    }

    .hero h1 em, .section-heading h2 em, .booking-copy h2 em, .contact-copy h2 em {
      font-style: italic;
      color: #f0c8d0;
    }

    .hero-text {
      max-width: 540px;
      font-size: 1rem;
      line-height: 1.8;
      color: rgba(255,255,255,0.84);
    }

    .hero-buttons {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
      margin-top: 2rem;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 52px;
      padding: 0.9rem 1.35rem;
      border-radius: 999px;
      transition: 0.25s ease;
      cursor: pointer;
      border: 1px solid transparent;
    }

    .btn-primary {
      background: linear-gradient(135deg, #f4d8de 0%, #c78d9a 100%);
      color: #261517;
      font-weight: 600;
      box-shadow: var(--shadow);
    }

    .btn-secondary {
      background: rgba(255,255,255,0.12);
      color: white;
      border-color: rgba(255,255,255,0.24);
    }

    .hero-side-card {
      justify-self: end;
      align-self: end;
      max-width: 340px;
      padding: 1.35rem;
      border-radius: var(--radius);
      background: rgba(255,255,255,0.14);
      backdrop-filter: blur(18px);
      color: #fff7f3;
      border: 1px solid rgba(255,255,255,0.16);
      box-shadow: var(--shadow);
    }

    .hero-side-card h2 {
      font-family: "Cormorant Garamond", serif;
      font-size: 2rem;
      line-height: 1;
      margin-bottom: 0.85rem;
    }

    .hero-side-card p {
      line-height: 1.7;
      color: rgba(255,255,255,0.78);
    }

    .section {
      padding: 7rem 0;
    }

    .section-tag {
      color: var(--wine);
      margin-bottom: 1rem;
    }

    .section-heading h2, .booking-copy h2, .contact-copy h2 {
      font-size: clamp(2.3rem, 5vw, 4.2rem);
      line-height: 0.98;
    }

    .featured-grid {
      margin-top: 2.5rem;
      display: grid;
      grid-template-columns: 1.2fr 0.8fr 0.8fr;
      gap: 1.2rem;
    }

    .featured-card {
      position: relative;
      min-height: 530px;
      border-radius: 28px;
      overflow: hidden;
      box-shadow: var(--shadow);
      background: #eadad8;
    }

    .featured-card img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .featured-content {
      position: absolute;
      inset: auto 0 0 0;
      padding: 1.4rem;
      color: white;
      background: linear-gradient(180deg, transparent 0%, rgba(0,0,0,0.68) 100%);
    }

    .featured-content h3 {
      font-family: "Cormorant Garamond", serif;
      font-size: 1.8rem;
      line-height: 1;
      max-width: 360px;
    }

    .service-list {
      margin-top: 2.25rem;
      display: grid;
      gap: 1rem;
    }

    .service-item {
      display: grid;
      grid-template-columns: 1.4fr 0.55fr 0.45fr;
      align-items: center;
      gap: 1rem;
      padding: 1.25rem;
      border: 1px solid var(--line);
      border-radius: 22px;
      background: rgba(255,255,255,0.52);
      backdrop-filter: blur(12px);
    }

    .service-item h3 {
      font-family: "Cormorant Garamond", serif;
      font-size: 1.8rem;
      font-weight: 500;
    }

    .service-item p {
      color: var(--muted);
      line-height: 1.6;
      font-size: 0.94rem;
    }

    .service-meta { text-align: right; }

    .service-duration {
      font-size: 0.74rem;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: var(--muted);
    }

    .service-price {
      font-family: "Cormorant Garamond", serif;
      font-size: 2rem;
      color: var(--wine);
    }

    .booking-shell, .contact-grid {
      display: grid;
      grid-template-columns: 0.8fr 1fr;
      gap: 1.5rem;
      align-items: start;
    }

    .booking-card, .contact-card {
      padding: 1.5rem;
      border-radius: 26px;
      box-shadow: var(--shadow);
    }

    .booking-card {
      background: rgba(255,255,255,0.72);
      border: 1px solid rgba(255,255,255,0.65);
      backdrop-filter: blur(16px);
    }

    .booking-card h3 {
      font-family: "Cormorant Garamond", serif;
      font-size: 2rem;
      margin-bottom: 0.4rem;
    }

    .booking-card p {
      color: var(--muted);
      line-height: 1.7;
      margin-bottom: 1.1rem;
    }

    .booking-card label {
      display: block;
      margin: 0.9rem 0 0.45rem;
      font-size: 0.76rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--wine);
    }

    .booking-card input,
    .booking-card select,
    .booking-card textarea {
      width: 100%;
      border: 1px solid rgba(0,0,0,0.08);
      background: rgba(255,255,255,0.7);
      border-radius: 16px;
      padding: 0.95rem 1rem;
      color: var(--ink);
      outline: none;
    }

    .booking-card textarea {
      min-height: 140px;
      resize: vertical;
    }

    .full { width: 100%; }

    .contact-copy p {
      margin-top: 1rem;
      color: var(--muted);
      line-height: 1.8;
      max-width: 560px;
    }

    .contact-card {
      background: linear-gradient(135deg, #241618 0%, #5b1f2e 100%);
      color: #fff6f3;
    }

    .contact-row {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      padding: 1rem 0;
      border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    .contact-row span {
      color: rgba(255,255,255,0.68);
      text-transform: uppercase;
      letter-spacing: 0.14em;
      font-size: 0.72rem;
    }

    .site-footer {
      padding: 2rem 0 3rem;
    }

    .footer-inner {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      align-items: center;
      border-top: 1px solid var(--line);
      padding-top: 1.3rem;
    }

    @keyframes heroZoom {
      from { transform: scale(1.12); }
      to { transform: scale(1.02); }
    }

    @media (max-width: 1100px) {
      .hero-overlay, .featured-grid, .booking-shell, .contact-grid {
        grid-template-columns: 1fr;
      }

      .hero-side-card {
        justify-self: start;
        max-width: 480px;
      }

      .featured-card {
        min-height: 420px;
      }
    }

    @media (max-width: 820px) {
      .desktop-nav { display: none; }
      .hero h1 { font-size: clamp(3rem, 16vw, 5.2rem); }
      .service-item { grid-template-columns: 1fr; }
      .service-meta { text-align: left; }
      .footer-inner, .contact-row { flex-direction: column; align-items: flex-start; }
    }
  </style>
</head>
<body>
  <header class="site-header" id="top">
    <a href="#top" class="brand">Nailed by <span>Mbuyi</span></a>
    <nav class="desktop-nav">
      <a href="#about">About</a>
      <a href="#featured">Featured Sets</a>
      <a href="#services">Services</a>
      <a href="#contact">Contact</a>
    </nav>
    <a href="#booking" class="header-book">Book now</a>
  </header>

  <main>
    <section class="hero">
      <div class="hero-media">
        <div class="hero-image-wrap">
          <img src="assets/hero/hero-nails.jpg" alt="Editorial nail set by Nailed by Mbuyi" class="hero-image" />
        </div>
        <div class="hero-gradient"></div>
      </div>

      <div class="hero-overlay container">
        <div class="hero-copy">
          <p class="hero-kicker">Luxury nail artistry · Eswatini</p>
          <h1>Editorial nails with <em>presence</em>.</h1>
          <p class="hero-text">
            Designed for women who want their nails to feel elevated, refined, and unforgettable.
            Soft detail. Bold finish. A set that looks expensive before you even speak.
          </p>
          <div class="hero-buttons">
            <a href="#booking" class="btn btn-primary">Book appointment</a>
            <a href="#featured" class="btn btn-secondary">View sets</a>
          </div>
        </div>

        <div class="hero-side-card">
          <p class="side-label">Current mood</p>
          <h2>Burgundy glass, soft pink, gold detail.</h2>
          <p>Clean structure, sculpted shape, and high-shine finish inspired by modern editorial beauty.</p>
        </div>
      </div>
    </section>

    <section class="section" id="featured">
      <div class="container">
        <div class="section-heading">
          <p class="section-tag">Featured sets</p>
          <h2>The first impression should feel <em>cinematic</em>.</h2>
        </div>

        <div class="featured-grid">
          <article class="featured-card">
            <img src="assets/gallery/gallery-1.jpg" alt="Featured set 1" />
            <div class="featured-content">
              <p class="featured-meta">Signature set</p>
              <h3>Playful colour, clean structure, soft finish</h3>
            </div>
          </article>

          <article class="featured-card">
            <img src="assets/gallery/gallery-2.jpg" alt="Featured set 2" />
            <div class="featured-content">
              <p class="featured-meta">Modern detail</p>
              <h3>Fresh detail with polished shape</h3>
            </div>
          </article>

          <article class="featured-card">
            <img src="assets/gallery/gallery-3.jpeg" alt="Featured set 3" />
            <div class="featured-content">
              <p class="featured-meta">Soft luxury</p>
              <h3>Gloss, balance, and premium finish</h3>
            </div>
          </article>
        </div>
          </article>
        </div>
      </div>
    </section>

    <section class="section" id="services">
      <div class="container">
        <div class="section-heading">
          <p class="section-tag">Services</p>
          <h2>Choose the set. Keep the <em>energy</em>.</h2>
        </div>

        <div class="service-list">
          <article class="service-item">
            <div>
              <h3>Rubberbase Overlay</h3>
              <p>Structured natural nail enhancement with a clean, polished finish.</p>
            </div>
            <div class="service-meta"><div class="service-duration">1h 20m</div></div>
            <div class="service-price">E250</div>
          </article>

          <article class="service-item">
            <div>
              <h3>Short Set + Art</h3>
              <p>Short sculpted set with detail that still feels tasteful and elevated.</p>
            </div>
            <div class="service-meta"><div class="service-duration">3h</div></div>
            <div class="service-price">From E380</div>
          </article>

          <article class="service-item">
            <div>
              <h3>Long Set + Art</h3>
              <p>Impactful length with premium finish and statement detail.</p>
            </div>
            <div class="service-meta"><div class="service-duration">4h</div></div>
            <div class="service-price">From E450</div>
          </article>
        </div>
      </div>
    </section>

    <section class="section" id="booking">
      <div class="container booking-shell">
        <div class="booking-copy">
          <p class="section-tag">Book</p>
          <h2>Ready for your next <em>set</em>?</h2>
          <p>Pick your service, then message on WhatsApp to confirm your preferred date, time, and design direction.</p>
        </div>

        <div class="booking-card">
          <h3>Quick booking</h3>
          <p>Select your service and jump straight into WhatsApp.</p>

          <label for="serviceSelect">Service</label>
          <select id="serviceSelect">
            <option>Short Set + Art — From E380</option>
            <option>Long Set + Art — From E450</option>
            <option>Rubberbase Overlay — E250</option>
          </select>

          <label for="bookingName">Your name</label>
          <input type="text" id="bookingName" placeholder="Your full name" />

          <label for="bookingDate">Preferred date</label>
          <input type="date" id="bookingDate" />

          <label for="bookingNotes">Notes / inspo</label>
          <textarea id="bookingNotes" placeholder="Shape, colour, art direction, or a short inspo note"></textarea>

          <button class="btn btn-primary full" type="button" onclick="sendBookingToWhatsApp()">
            Continue to WhatsApp
          </button>
        </div>
      </div>
    </section>

    <section class="section" id="contact">
      <div class="container contact-grid">
        <div class="contact-copy">
          <p class="section-tag">Contact</p>
          <h2>Let’s create something <em>beautiful</em>.</h2>
          <p>For booking questions, custom design requests, or payment proof, reach out directly on WhatsApp.</p>
        </div>

        <div class="contact-card">
          <div class="contact-row">
            <span>WhatsApp</span>
            <strong>+268 79 466 818</strong>
          </div>
          <div class="contact-row">
            <span>Instagram</span>
            <strong>@nailedbymbuyi</strong>
          </div>
          <div class="contact-row">
            <span>Location</span>
            <strong>Mbabane, Eswatini</strong>
          </div>
          <a href="https://wa.me/26879466818" target="_blank" rel="noopener noreferrer" class="btn btn-secondary full">
            Chat on WhatsApp
          </a>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container footer-inner">
      <a href="#top" class="brand footer-brand">Nailed by <span>Mbuyi</span></a>
      <p>Luxury nail artistry in Eswatini.</p>
    </div>
  </footer>

  <script>
    function sendBookingToWhatsApp() {
      const service = document.getElementById("serviceSelect").value;
      const name = document.getElementById("bookingName").value.trim();
      const date = document.getElementById("bookingDate").value;
      const notes = document.getElementById("bookingNotes").value.trim();

      if (!service || !name || !date) {
        alert("Please select a service and add your name and preferred date.");
        return;
      }

      const message = encodeURIComponent(
        `Hi Nailed by Mbuyi 👋\n\nI would like to book:\nService: ${service}\nName: ${name}\nPreferred date: ${date}\nNotes/Inspo: ${notes || "None yet"}\n\nPlease let me know the next available time slot and payment details.`
      );

      window.open(`https://wa.me/26879466818?text=${message}`, "_blank");
    }
  </script>
</body>
</html>
