<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#f5efe9" />
  <meta name="description" content="Nailed by Mbuyi — luxury nail artistry in Eswatini." />
  <title>Nailed by Mbuyi — Nail Artistry</title>
  <link rel="icon" href="data:,">

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <style>
    :root {
      --bg: #f5efe9;
      --ink: #171313;
      --muted: #6b5d59;
      --wine: #5b1f2e;
      --rose: #d6a4af;
      --line: rgba(23, 19, 19, 0.08);
      --shadow: 0 18px 50px rgba(16, 10, 10, 0.12);
      --radius: 24px;
      --container: 1240px;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    body {
      font-family: "Inter", sans-serif;
      color: var(--ink);
      background:
        radial-gradient(circle at top left, rgba(214, 164, 175, 0.18), transparent 25%),
        radial-gradient(circle at bottom right, rgba(91, 31, 46, 0.12), transparent 24%),
        var(--bg);
      overflow-x: hidden;
    }

    img { display: block; max-width: 100%; }
    a { color: inherit; text-decoration: none; }
    .container { width: min(var(--container), calc(100% - 2.5rem)); margin: 0 auto; }

    .site-header {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 30;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1rem 1.25rem;
      backdrop-filter: blur(14px);
      background: rgba(245, 239, 233, 0.58);
      border-bottom: 1px solid rgba(255,255,255,0.35);
    }

    .brand {
      font-family: "Cormorant Garamond", serif;
      font-size: 1.7rem;
      font-weight: 500;
    }

    .brand span {
      color: var(--wine);
      font-style: italic;
    }

    .desktop-nav {
      display: flex;
      gap: 2rem;
    }

    .desktop-nav a, .header-book {
      font-size: 0.82rem;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: var(--muted);
    }

    .hero {
      min-height: 100vh !important;
      height: 100vh !important;
      display: block !important;
      position: relative !important;
      overflow: hidden !important;
      padding-top: 82px !important;
      background: #120d10 !important;
    }

    .hero-media {
      position: absolute !important;
      inset: 82px 0 0 0 !important;
      width: 100% !important;
      height: calc(100vh - 82px) !important;
      overflow: hidden !important;
    }

    .hero-image-wrap {
      position: absolute !important;
      inset: 0 !important;
      width: 100% !important;
      height: 100% !important;
      overflow: hidden !important;
      background: #120d10 !important;
    }

    .hero-image {
      width: 100% !important;
      height: 100% !important;
      object-fit: cover !important;
      object-position: center 38% !important;
      transform: none !important;
      animation: none !important;
      filter: saturate(1.03) contrast(1.02) !important;
      display: block !important;
    }

    .hero-gradient {
      position: absolute !important;
      inset: 0 !important;
      background:
        linear-gradient(90deg, rgba(10, 8, 10, 0.62) 0%, rgba(10, 8, 10, 0.20) 42%, rgba(10, 8, 10, 0.18) 100%),
        linear-gradient(180deg, rgba(10, 8, 10, 0.14) 0%, rgba(10, 8, 10, 0.18) 100%) !important;
      pointer-events: none !important;
    }

    .hero-overlay {
      position: relative !important;
      z-index: 2 !important;
      min-height: calc(100vh - 82px) !important;
      display: grid !important;
      grid-template-columns: 1.1fr 0.7fr !important;
      align-items: end !important;
      gap: 2rem !important;
      padding-top: 0 !important;
      padding-bottom: 2.2rem !important;
    }

    .hero-copy {
      color: #fff8f5;
      max-width: 720px;
      padding-bottom: 2rem;
    }

    .hero-kicker, .section-tag, .featured-meta, .side-label {
      font-size: 0.75rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }

    .hero-kicker, .side-label {
      color: rgba(255,255,255,0.76);
      margin-bottom: 1rem;
    }

    .hero h1, .section-heading h2, .booking-copy h2, .contact-copy h2 {
      font-family: "Cormorant Garamond", serif;
      font-weight: 400;
      line-height: 0.95;
    }

    .hero h1 {
      font-size: clamp(3.7rem, 9vw, 8rem);
      margin-bottom: 1rem;
      letter-spacing: -0.03em;
    }

    .hero h1 em, .section-heading h2 em, .booking-copy h2 em, .contact-copy h2 em {
      font-style: italic;
      color: #f0c8d0;
    }

    .hero-text {
      max-width: 540px;
      font-size: 1rem;
      line-height: 1.8;
      color: rgba(255,255,255,0.84);
    }

    .hero-buttons {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
      margin-top: 2rem;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 52px;
      padding: 0.9rem 1.35rem;
      border-radius: 999px;
      transition: 0.25s ease;
      cursor: pointer;
      border: 1px solid transparent;
    }

    .btn-primary {
      background: linear-gradient(135deg, #f4d8de 0%, #c78d9a 100%);
      color: #261517;
      font-weight: 600;
      box-shadow: var(--shadow);
    }

    .btn-secondary {
      background: rgba(255,255,255,0.12);
      color: white;
      border-color: rgba(255,255,255,0.24);
    }

    .hero-side-card {
      justify-self: end;
      align-self: end;
      max-width: 340px;
      padding: 1.35rem;
      border-radius: var(--radius);
      background: rgba(255,255,255,0.14);
      backdrop-filter: blur(18px);
      color: #fff7f3;
      border: 1px solid rgba(255,255,255,0.16);
      box-shadow: var(--shadow);
    }

    .hero-side-card h2 {
      font-family: "Cormorant Garamond", serif;
      font-size: 2rem;
      line-height: 1;
      margin-bottom: 0.85rem;
    }

    .hero-side-card p {
      line-height: 1.7;
      color: rgba(255,255,255,0.78);
    }

    .section {
      padding: 7rem 0;
    }

    .section-tag {
      color: var(--wine);
      margin-bottom: 1rem;
    }

    .section-heading h2, .booking-copy h2, .contact-copy h2 {
      font-size: clamp(2.3rem, 5vw, 4.2rem);
      line-height: 0.98;
    }

    .featured-grid {
      margin-top: 2.5rem;
      display: grid;
      grid-template-columns: 1.2fr 0.8fr 0.8fr;
      gap: 1.2rem;
    }

    .featured-card {
      position: relative;
      min-height: 530px;
      border-radius: 28px;
      overflow: hidden;
      box-shadow: var(--shadow);
      background: #eadad8;
    }

    .featured-card img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .featured-content {
      position: absolute;
      inset: auto 0 0 0;
      padding: 1.4rem;
      color: white;
      background: linear-gradient(180deg, transparent 0%, rgba(0,0,0,0.68) 100%);
    }

    .featured-content h3 {
      font-family: "Cormorant Garamond", serif;
      font-size: 1.8rem;
      line-height: 1;
      max-width: 360px;
    }

    .service-list {
      margin-top: 2.25rem;
      display: grid;
      gap: 1rem;
    }

    .service-item {
      display: grid;
      grid-template-columns: 1.4fr 0.55fr 0.45fr;
      align-items: center;
      gap: 1rem;
      padding: 1.25rem;
      border: 1px solid var(--line);
      border-radius: 22px;
      background: rgba(255,255,255,0.52);
      backdrop-filter: blur(12px);
    }

    .service-item h3 {
      font-family: "Cormorant Garamond", serif;
      font-size: 1.8rem;
      font-weight: 500;
    }

    .service-item p {
      color: var(--muted);
      line-height: 1.6;
      font-size: 0.94rem;
    }

    .service-meta { text-align: right; }

    .service-duration {
      font-size: 0.74rem;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: var(--muted);
    }

    .service-price {
      font-family: "Cormorant Garamond", serif;
      font-size: 2rem;
      color: var(--wine);
    }

    .booking-shell, .contact-grid {
      display: grid;
      grid-template-columns: 0.8fr 1fr;
      gap: 1.5rem;
      align-items: start;
    }

    .booking-card, .contact-card {
      padding: 1.5rem;
      border-radius: 26px;
      box-shadow: var(--shadow);
    }

    .booking-card {
      background: rgba(255,255,255,0.72);
      border: 1px solid rgba(255,255,255,0.65);
      backdrop-filter: blur(16px);
    }

    .booking-card h3 {
      font-family: "Cormorant Garamond", serif;
      font-size: 2rem;
      margin-bottom: 0.4rem;
    }

    .booking-card p {
      color: var(--muted);
      line-height: 1.7;
      margin-bottom: 1.1rem;
    }

    .booking-card label {
      display: block;
      margin: 0.9rem 0 0.45rem;
      font-size: 0.76rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--wine);
    }

    .booking-card input,
    .booking-card select,
    .booking-card textarea {
      width: 100%;
      border: 1px solid rgba(0,0,0,0.08);
      background: rgba(255,255,255,0.7);
      border-radius: 16px;
      padding: 0.95rem 1rem;
      color: var(--ink);
      outline: none;
    }

    .booking-card textarea {
      min-height: 140px;
      resize: vertical;
    }

    .full { width: 100%; }

    .contact-copy p {
      margin-top: 1rem;
      color: var(--muted);
      line-height: 1.8;
      max-width: 560px;
    }

    .contact-card {
      background: linear-gradient(135deg, #241618 0%, #5b1f2e 100%);
      color: #fff6f3;
    }

    .contact-row {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      padding: 1rem 0;
      border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    .contact-row span {
      color: rgba(255,255,255,0.68);
      text-transform: uppercase;
      letter-spacing: 0.14em;
      font-size: 0.72rem;
    }

    .site-footer {
      padding: 2rem 0 3rem;
    }

    .footer-inner {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      align-items: center;
      border-top: 1px solid var(--line);
      padding-top: 1.3rem;
    }

    @keyframes heroZoom {
      from { transform: scale(1.12); }
      to { transform: scale(1.02); }
    }

    @media (max-width: 1100px) {
      .hero-overlay, .featured-grid, .booking-shell, .contact-grid {
        grid-template-columns: 1fr;
      }

      .hero-side-card {
        justify-self: start;
        max-width: 480px;
      }

      .featured-card {
        min-height: 420px;
      }
    }

    @media (max-width: 820px) {
      .desktop-nav { display: none; }
      .hero h1 { font-size: clamp(3rem, 16vw, 5.2rem); }
      .service-item { grid-template-columns: 1fr; }
      .service-meta { text-align: left; }
      .footer-inner, .contact-row { flex-direction: column; align-items: flex-start; }
    }
  
    body {
      -webkit-text-size-adjust: 100%;
      text-rendering: optimizeLegibility;
    }

    img {
      height: auto;
    }

    .featured-shell {
      position: relative;
      margin-top: 2.5rem;
    }

    .featured-arrow {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      z-index: 5;
      width: 42px;
      height: 42px;
      border: 1px solid rgba(255,255,255,0.18);
      border-radius: 999px;
      background: rgba(255,255,255,0.10);
      color: rgba(255,255,255,0.78);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      box-shadow: 0 10px 24px rgba(0,0,0,0.10);
      cursor: pointer;
      font-size: 1.35rem;
      opacity: 0.52;
      transition: opacity 0.22s ease, background 0.22s ease, transform 0.22s ease;
    }

    .featured-arrow:hover {
      opacity: 0.9;
      background: rgba(255,255,255,0.18);
    }

    .featured-arrow-left { left: -14px; }
    .featured-arrow-right { right: -14px; }

    .featured-grid {
      scroll-behavior: smooth;
    }

    .featured-card {
      -webkit-user-select: none;
      user-select: none;
    }

    .booking-card input,
    .booking-card select,
    .booking-card textarea,
    .btn,
    button {
      -webkit-appearance: none;
      appearance: none;
    }

    .booking-card input,
    .booking-card select,
    .booking-card textarea {
      font-size: 16px;
    }

    @media (max-width: 1100px) {
      .featured-arrow-left { left: 8px; }
      .featured-arrow-right { right: 8px; }
    }

    @media (max-width: 820px) {
      .featured-grid {
        display: flex;
        gap: 1rem;
        overflow-x: auto;
        overscroll-behavior-x: contain;
        scroll-snap-type: x mandatory;
        -webkit-overflow-scrolling: touch;
        padding: 0.2rem 0.2rem 0.75rem;
        margin-top: 0;
      }

      .featured-grid::-webkit-scrollbar {
        display: none;
      }

      .featured-card {
        min-width: 86vw;
        max-width: 86vw;
        scroll-snap-align: center;
        flex: 0 0 86vw;
        min-height: 420px;
      }

      .featured-content h3 {
        font-size: 1.5rem;
      }

      .featured-arrow {
        width: 38px;
        height: 38px;
        font-size: 1.15rem;
        opacity: 0.42;
      }
    }

    @media (max-width: 520px) {
      .featured-card {
        min-width: 88vw;
        max-width: 88vw;
        flex-basis: 88vw;
        min-height: 380px;
      }

      .hero-side-card {
        max-width: 100%;
      }

      .site-header {
        padding: 0.9rem 0.9rem;
      }

      .hero-overlay {
      position: relative !important;
      z-index: 2 !important;
      min-height: calc(100vh - 82px) !important;
      display: grid !important;
      grid-template-columns: 1.1fr 0.7fr !important;
      align-items: end !important;
      gap: 2rem !important;
      padding-top: 0 !important;
      padding-bottom: 2.2rem !important;
    }
    }

  
    .service-gallery-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 1.25rem;
      margin-top: 1.8rem;
    }

    .service-gallery-card {
      position: relative;
      border-radius: 26px;
      overflow: hidden;
      background: rgba(255,255,255,0.62);
      box-shadow: 0 18px 40px rgba(16, 10, 10, 0.10);
      border: 1px solid rgba(23, 19, 19, 0.06);
    }

    .service-gallery-card img {
      width: 100%;
      height: 360px;
      object-fit: cover;
      display: block;
    }

    .service-gallery-copy {
      padding: 1rem 1rem 1.15rem;
      background: rgba(255,255,255,0.84);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
    }

    .service-gallery-copy h3 {
      font-family: "Cormorant Garamond", serif;
      font-size: 1.55rem;
      line-height: 1.05;
      margin-bottom: 0.35rem;
      color: var(--ink);
    }

    .service-gallery-copy p {
      color: var(--muted);
      font-size: 0.92rem;
      line-height: 1.6;
    }

    .service-price-tag {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 30px;
      padding: 0.25rem 0.65rem;
      border-radius: 999px;
      background: rgba(91,31,46,0.10);
      color: var(--wine);
      font-size: 0.72rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-bottom: 0.7rem;
      font-weight: 600;
    }

    @media (max-width: 700px) {
      .service-gallery-card img {
        height: 300px;
      }

      .service-gallery-copy h3 {
        font-size: 1.35rem;
      }
    }

  </style>

  <style id="final-polish-override">
    /* ===== FINAL POLISH OVERRIDE ===== */

    .hero-image-wrap {
      position: absolute !important;
      inset: 0 !important;
      width: 100% !important;
      height: 100% !important;
      overflow: hidden !important;
      background: #120d10 !important;
    }

    .hero-image {
      width: 100% !important;
      height: 100% !important;
      object-fit: cover !important;
      object-position: center 38% !important;
      transform: none !important;
      animation: none !important;
      filter: saturate(1.03) contrast(1.02) !important;
      display: block !important;
    }

    .hero-gradient {
      position: absolute !important;
      inset: 0 !important;
      background:
        linear-gradient(90deg, rgba(10, 8, 10, 0.62) 0%, rgba(10, 8, 10, 0.20) 42%, rgba(10, 8, 10, 0.18) 100%),
        linear-gradient(180deg, rgba(10, 8, 10, 0.14) 0%, rgba(10, 8, 10, 0.18) 100%) !important;
      pointer-events: none !important;
    }

    .featured-shell {
      position: relative;
      margin-top: 2.5rem;
    }

    .featured-grid {
      display: flex !important;
      flex-wrap: nowrap !important;
      gap: 1rem;
      overflow-x: auto;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      overscroll-behavior-x: contain;
      scroll-behavior: smooth;
      padding: 0.25rem 0 0.75rem;
    }

    .featured-grid::-webkit-scrollbar {
      display: none;
    }

    .featured-card {
      flex: 0 0 28rem !important;
      min-width: 28rem !important;
      max-width: 28rem !important;
      min-height: 28rem !important;
      border-radius: 28px;
      overflow: hidden;
    }

    .featured-card img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .featured-arrow {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      z-index: 6;
      width: 38px;
      height: 38px;
      border: 1px solid rgba(255,255,255,0.14);
      border-radius: 999px;
      background: rgba(255,255,255,0.10);
      color: rgba(255,255,255,0.78);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      box-shadow: 0 10px 24px rgba(0,0,0,0.10);
      cursor: pointer;
      font-size: 1.1rem;
      opacity: 0.38;
      transition: opacity .2s ease, background .2s ease;
    }

    .featured-arrow:hover {
      opacity: 0.85;
      background: rgba(255,255,255,0.18);
    }

    .featured-arrow-left { left: -12px; }
    .featured-arrow-right { right: -12px; }

    @media (max-width: 900px) {
      .featured-card {
        flex-basis: 82vw !important;
        min-width: 82vw !important;
        max-width: 82vw !important;
        min-height: 24rem !important;
      }

      .featured-arrow-left { left: 8px; }
      .featured-arrow-right { right: 8px; }
    }

    @media (max-width: 520px) {
      .hero-image {
      width: 100% !important;
      height: 100% !important;
      object-fit: cover !important;
      object-position: center 38% !important;
      transform: none !important;
      animation: none !important;
      filter: saturate(1.03) contrast(1.02) !important;
      display: block !important;
    }

      .featured-card {
        flex-basis: 86vw !important;
        min-width: 86vw !important;
        max-width: 86vw !important;
        min-height: 21rem !important;
      }

      .featured-content h3 {
        font-size: 1.3rem;
        line-height: 1.25;
      }
    }
  </style>


  <style id="final-layout-fix">
    /* ===== HERO: true landscape split layout ===== */
    .hero {
      min-height: 100vh !important;
      height: 100vh !important;
      display: block !important;
      position: relative !important;
      overflow: hidden !important;
      padding-top: 82px !important;
      background: #120d10 !important;
    }

    .hero-media {
      position: absolute !important;
      inset: 82px 0 0 0 !important;
      width: 100% !important;
      height: calc(100vh - 82px) !important;
      overflow: hidden !important;
    }

    .hero-image-wrap {
      position: absolute !important;
      inset: 0 !important;
      width: 100% !important;
      height: 100% !important;
      overflow: hidden !important;
      background: #120d10 !important;
    }

    .hero-image {
      width: 100% !important;
      height: 100% !important;
      object-fit: cover !important;
      object-position: center 38% !important;
      transform: none !important;
      animation: none !important;
      filter: saturate(1.03) contrast(1.02) !important;
      display: block !important;
    }

    .hero-gradient {
      position: absolute !important;
      inset: 0 !important;
      background:
        linear-gradient(90deg, rgba(10, 8, 10, 0.62) 0%, rgba(10, 8, 10, 0.20) 42%, rgba(10, 8, 10, 0.18) 100%),
        linear-gradient(180deg, rgba(10, 8, 10, 0.14) 0%, rgba(10, 8, 10, 0.18) 100%) !important;
      pointer-events: none !important;
    }

    .hero-overlay {
      position: relative !important;
      z-index: 2 !important;
      min-height: calc(100vh - 82px) !important;
      display: grid !important;
      grid-template-columns: 1.1fr 0.7fr !important;
      align-items: end !important;
      gap: 2rem !important;
      padding-top: 0 !important;
      padding-bottom: 2.2rem !important;
    }

    .hero-copy {
      grid-column: 1 !important;
      align-self: center !important;
      padding-bottom: 0 !important;
      max-width: 760px !important;
    }

    .hero-side-card {
      grid-column: 2 !important;
      justify-self: end !important;
      align-self: end !important;
      margin: 0 1.5rem 2rem 0 !important;
    }

    .scroll-cue {
      display: none !important;
    }

    /* ===== FEATURED: end-to-end clean slider ===== */
    .featured-shell {
      position: relative !important;
      width: 100vw !important;
      margin-left: calc(50% - 50vw) !important;
      margin-top: 2.5rem !important;
    }

    .featured-grid {
      display: flex !important;
      flex-wrap: nowrap !important;
      gap: 1rem !important;
      overflow-x: auto !important;
      overflow-y: hidden !important;
      scroll-snap-type: x mandatory !important;
      -webkit-overflow-scrolling: touch !important;
      overscroll-behavior-x: contain !important;
      scroll-behavior: smooth !important;
      padding: 0 1.5rem 0.75rem !important;
      margin: 0 !important;
    }

    .featured-grid::-webkit-scrollbar {
      display: none !important;
    }

    .featured-card {
      flex: 0 0 33vw !important;
      min-width: 33vw !important;
      max-width: 33vw !important;
      min-height: 30rem !important;
      border-radius: 28px !important;
      overflow: hidden !important;
    }

    .featured-card img {
      width: 100% !important;
      height: 100% !important;
      object-fit: cover !important;
      display: block !important;
    }

    .featured-arrow {
      position: absolute !important;
      top: 50% !important;
      transform: translateY(-50%) !important;
      z-index: 10 !important;
      width: 40px !important;
      height: 40px !important;
      border: 1px solid rgba(255,255,255,0.14) !important;
      border-radius: 999px !important;
      background: rgba(255,255,255,0.12) !important;
      color: rgba(255,255,255,0.84) !important;
      backdrop-filter: blur(10px) !important;
      -webkit-backdrop-filter: blur(10px) !important;
      box-shadow: 0 10px 24px rgba(0,0,0,0.10) !important;
      cursor: pointer !important;
      font-size: 1.15rem !important;
      opacity: 0.45 !important;
    }

    .featured-arrow-left { left: 10px !important; }
    .featured-arrow-right { right: 10px !important; }

    @media (max-width: 1100px) {
      .hero {
      min-height: 100vh !important;
      height: 100vh !important;
      display: block !important;
      position: relative !important;
      overflow: hidden !important;
      padding-top: 82px !important;
      background: #120d10 !important;
    }

      .hero-media {
      position: absolute !important;
      inset: 82px 0 0 0 !important;
      width: 100% !important;
      height: calc(100vh - 82px) !important;
      overflow: hidden !important;
    }

      .hero-overlay {
      position: relative !important;
      z-index: 2 !important;
      min-height: calc(100vh - 82px) !important;
      display: grid !important;
      grid-template-columns: 1.1fr 0.7fr !important;
      align-items: end !important;
      gap: 2rem !important;
      padding-top: 0 !important;
      padding-bottom: 2.2rem !important;
    }

      .hero-copy {
        padding: 0 1.5rem !important;
      }

      .hero-side-card {
        grid-column: 1 !important;
        justify-self: start !important;
        margin: 0 1.5rem !important;
      }

      .featured-card {
        flex-basis: 56vw !important;
        min-width: 56vw !important;
        max-width: 56vw !important;
      }
    }

    @media (max-width: 700px) {
      .hero-image {
      width: 100% !important;
      height: 100% !important;
      object-fit: cover !important;
      object-position: center 38% !important;
      transform: none !important;
      animation: none !important;
      filter: saturate(1.03) contrast(1.02) !important;
      display: block !important;
    }

      .featured-card {
        flex-basis: 86vw !important;
        min-width: 86vw !important;
        max-width: 86vw !important;
        min-height: 24rem !important;
      }

      .featured-content h3 {
        font-size: 1.35rem !important;
        line-height: 1.2 !important;
      }
    }
  </style>


  <style id="hero-mobile-fix">
    @media (max-width: 900px) {
      .hero {
        height: auto !important;
        min-height: 100svh !important;
      }

      .hero-media {
        inset: 82px 0 0 0 !important;
        height: 54svh !important;
      }

      .hero-image {
        object-position: center 32% !important;
      }

      .hero-overlay {
        min-height: auto !important;
        grid-template-columns: 1fr !important;
        padding-top: 56svh !important;
        padding-bottom: 1.5rem !important;
      }

      .hero-side-card {
        justify-self: start !important;
        margin-right: 0 !important;
      }
    }
  </style>


  <style id="spacing-polish">

    /* ===== GLOBAL SECTION SPACING ===== */
    .section {
      padding: 3.5rem 0 !important;
    }

    .section:first-of-type {
      padding-top: 2.5rem !important;
    }

    .section:last-of-type {
      padding-bottom: 3rem !important;
    }

    /* ===== HEADINGS ===== */
    .section-heading {
      margin-bottom: 1.8rem !important;
    }

    .section-heading h2 {
      margin-bottom: 0.6rem !important;
    }

    /* ===== FEATURED ===== */
    .featured-shell {
      margin-top: 1.5rem !important;
    }

    .featured-grid {
      padding-bottom: 0.4rem !important;
    }

    .featured-card {
      min-height: 26rem !important;
    }

    /* ===== HERO ===== */
    .hero-overlay {
      padding-bottom: 1.2rem !important;
    }

    .hero-copy {
      gap: 0.8rem !important;
    }

    /* ===== CONTACT / FOOTER ===== */
    .contact-row {
      margin-bottom: 0.6rem !important;
    }

    /* ===== MOBILE ===== */
    @media (max-width: 700px) {
      .section {
        padding: 2.4rem 0 !important;
      }

      .section-heading {
        margin-bottom: 1.2rem !important;
      }

      .featured-card {
        min-height: 22rem !important;
      }
    }

  </style>


  <style id="signature-style">
    .site-signature {
      text-align: center;
      font-size: 0.7rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(0,0,0,0.45);
      margin: 2rem 0 1.5rem;
      font-family: 'Jost', sans-serif;
    }

    .site-signature strong {
      font-weight: 500;
      color: rgba(0,0,0,0.65);
      margin-left: 0.4rem;
    }
  </style>


  <style id="hide-hero-arrow">
    .scroll-cue,
    .hero .scroll-cue,
    .hero-arrow,
    .hero .hero-arrow {
      display: none !important;
      opacity: 0 !important;
      visibility: hidden !important;
      pointer-events: none !important;
    }
  </style>

</head>
<body>
  <header class="site-header" id="top">
    <a href="#top" class="brand">Nailed by <span>Mbuyi</span></a>
    <nav class="desktop-nav">
      <a href="#about">About</a>
      <a href="#featured">Featured Sets</a>
      <a href="#services">Services</a>
      <a href="#contact">Contact</a>
    </nav>
    <a href="#booking" class="header-book">Book now</a>
  </header>

  <main>
    <section class="hero">
      <div class="hero-media">
        <div class="hero-image-wrap">
          <img src="assets/hero/hero-nails.jpg" alt="Editorial nail set by Nailed by Mbuyi" class="hero-image" />
        </div>
        <div class="hero-gradient"></div>
      </div>

      <div class="hero-overlay container">
        <div class="hero-copy">
          <p class="hero-kicker">Luxury nail artistry · Eswatini</p>
          <h1>Editorial nails with <em>presence</em>.</h1>
          <p class="hero-text">
            Designed for women who want their nails to feel elevated, refined, and unforgettable.
            Soft detail. Bold finish. A set that looks expensive before you even speak.
          </p>
          <div class="hero-buttons">
            <a href="#booking" class="btn btn-primary">Book appointment</a>
            <a href="#featured" class="btn btn-secondary">View sets</a>
          </div>
        </div>

        <div class="hero-side-card">
          <p class="side-label">Current mood</p>
          <h2>Burgundy glass, soft pink, gold detail.</h2>
          <p>Clean structure, sculpted shape, and high-shine finish inspired by modern editorial beauty.</p>
          </div>
          <button class="featured-arrow featured-arrow-right" type="button" aria-label="Scroll featured services right" onclick="scrollFeatured(1)">›</button>
        </div>
      </div>
    </section>

    
    
    
    <section class="section" id="featured">
      <div class="container">
        <div class="section-heading">
          <p class="section-tag">Featured sets</p>
          <h2>The first impression should feel <em>cinematic</em>.</h2>
        </div>

        <div class="featured-shell">
          <button class="featured-arrow featured-arrow-left" type="button" aria-label="Scroll featured sets left" onclick="scrollFeatured(-1)">‹</button>

          <div class="featured-grid" id="featuredGrid">
            <article class="featured-card">
              <img src="assets/gallery/hands.jpeg" alt="Hands set" />
              <div class="featured-content">
                <p class="featured-meta">Hands</p>
                <h3>Clean detail with polished structure</h3>
              </div>
            </article>

            <article class="featured-card">
              <img src="assets/gallery/manicure.jpeg" alt="Manicure set" />
              <div class="featured-content">
                <p class="featured-meta">Manicure</p>
                <h3>Refined finish with soft luxury</h3>
              </div>
            </article>

            <article class="featured-card">
              <img src="assets/gallery/pedicure.jpeg" alt="Pedicure set" />
              <div class="featured-content">
                <p class="featured-meta">Pedicure</p>
                <h3>Fresh, elegant, and beautifully finished</h3>
              </div>
            </article>

            <article class="featured-card">
              <img src="assets/gallery/emojis.jpeg" alt="Emoji set" />
              <div class="featured-content">
                <p class="featured-meta">Playful detail</p>
                <h3>Fun expression with a premium touch</h3>
              </div>
            </article>
          </div>

          <button class="featured-arrow featured-arrow-right" type="button" aria-label="Scroll featured sets right" onclick="scrollFeatured(1)">›</button>
        </div>
      </div>
    </section>




    
    <section class="section" id="services">
      <div class="container">
        <div class="section-heading">
          <p class="section-tag">Services</p>
          <h2>Our service menu in <em>full view</em>.</h2>
        </div>

        <div class="service-gallery-grid">
          <article class="service-gallery-card">
            <img src="assets/services/gel-overlay-e200.jpeg" alt="Gel overlay E200" />
            <div class="service-gallery-copy">
              <span class="service-price-tag">E200</span>
              <h3>Gel overlay</h3>
              <p>Gel overlay · E200</p>
            </div>
          </article>

          <article class="service-gallery-card">
            <img src="assets/services/buff-and-shine-e150.jpeg" alt="Buff and shine E150" />
            <div class="service-gallery-copy">
              <span class="service-price-tag">E150</span>
              <h3>Buff and shine</h3>
              <p>Buff and shine · E150</p>
            </div>
          </article>

          <article class="service-gallery-card">
            <img src="assets/services/rubberbase-colour-e250.jpeg" alt="Rubberbase + colour E250" />
            <div class="service-gallery-copy">
              <span class="service-price-tag">E250</span>
              <h3>Rubberbase + colour</h3>
              <p>Rubberbase + colour · E250</p>
            </div>
          </article>

          <article class="service-gallery-card">
            <img src="assets/services/rubberbase-colour-medium-art-e270.jpg" alt="Rubberbase colour + medium art E270" />
            <div class="service-gallery-copy">
              <span class="service-price-tag">E270</span>
              <h3>Rubberbase colour + medium art</h3>
              <p>Rubberbase colour + medium art · E270</p>
            </div>
          </article>

          <article class="service-gallery-card">
            <img src="assets/services/rubberbase-colour-advanced-art-e290.jpeg" alt="Rubberbase colour + advanced art E290" />
            <div class="service-gallery-copy">
              <span class="service-price-tag">E290</span>
              <h3>Rubberbase colour + advanced art</h3>
              <p>Rubberbase colour + advanced art · E290</p>
            </div>
          </article>

          <article class="service-gallery-card">
            <img src="assets/services/advanced-nail-art-e290.jpg" alt="Advanced nail art E290" />
            <div class="service-gallery-copy">
              <span class="service-price-tag">E290</span>
              <h3>Advanced nail art</h3>
              <p>Advanced nail art · E290</p>
            </div>
          </article>

          <article class="service-gallery-card">
            <img src="assets/services/mini-manicure-kids-e80-e120.jpeg" alt="Mini Manicure Kids E80-E120" />
            <div class="service-gallery-copy">
              <span class="service-price-tag">E80–E120</span>
              <h3>Mini Manicure (Kids)</h3>
              <p>Mini Manicure (Kids) · E80–E120</p>
            </div>
          </article>
        </div>
      </div>
    </section>


    <section class="section" id="booking">
      <div class="container booking-shell">
        <div class="booking-copy">
          <p class="section-tag">Book</p>
          <h2>Ready for your next <em>set</em>?</h2>
          <p>Pick your service, then message on WhatsApp to confirm your preferred date, time, and design direction.</p>
        </div>

        <div class="booking-card">
          <h3>Quick booking</h3>
          <p>Select your service and jump straight into WhatsApp.</p>

          <label for="serviceSelect">Service</label>
          <select id="serviceSelect">
            <option>Short Set + Art — From E380</option>
            <option>Long Set + Art — From E450</option>
            <option>Rubberbase Overlay — E250</option>
          </select>

          <label for="bookingName">Your name</label>
          <input type="text" id="bookingName" placeholder="Your full name" />

          <label for="bookingDate">Preferred date</label>
          <input type="date" id="bookingDate" />

          <label for="bookingNotes">Notes / inspo</label>
          <textarea id="bookingNotes" placeholder="Shape, colour, art direction, or a short inspo note"></textarea>

          <button class="btn btn-primary full" type="button" onclick="sendBookingToWhatsApp()">
            Continue to WhatsApp
          </button>
        </div>
      </div>
    </section>

    <section class="section" id="contact">
      <div class="container contact-grid">
        <div class="contact-copy">
          <p class="section-tag">Contact</p>
          <h2>Let’s create something <em>beautiful</em>.</h2>
          <p>For booking questions, custom design requests, or payment proof, reach out directly on WhatsApp.</p>
        </div>

        <div class="contact-card">
          <div class="contact-row">
            <span>WhatsApp</span>
            <strong>78166787</strong>
          </div>
          <div class="contact-row">
            <span>Instagram</span>
            <strong>@nailed_by_mbuyi</strong>
          </div>
          <div class="contact-row">
            <span>Email</span>
            <strong>mbuyiselo202@gmail.com</strong>
          </div>
          <div class="contact-row">
            <span>Location</span>
            <strong>Mbabane, Eswatini</strong>
          </div>
          <a href="https://wa.me/26878166787" target="_blank" rel="noopener noreferrer" class="btn btn-secondary full">
            Chat on WhatsApp
          </a>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container footer-inner">
      <a href="#top" class="brand footer-brand">Nailed by <span>Mbuyi</span></a>
      <p>Luxury nail artistry in Eswatini.</p>
    </div>
  </footer>

  <script>

    function scrollFeatured(direction) {
      const grid = document.getElementById("featuredGrid");
      if (!grid) return;

      const card = grid.querySelector(".featured-card");
      const amount = card ? card.offsetWidth + 16 : 320;

      grid.scrollLeft += amount * direction;
    });
    }

    function sendBookingToWhatsApp() {
      const service = document.getElementById("serviceSelect").value;
      const name = document.getElementById("bookingName").value.trim();
      const date = document.getElementById("bookingDate").value;
      const notes = document.getElementById("bookingNotes").value.trim();

      if (!service || !name || !date) {
        alert("Please select a service and add your name and preferred date.");
        return;
      }

      const message = encodeURIComponent(
        `Hi Nailed by Mbuyi 👋\n\nI would like to book:\nService: ${service}\nName: ${name}\nPreferred date: ${date}\nNotes/Inspo: ${notes || "None yet"}\n\nPlease let me know the next available time slot and payment details.`
      );

      window.open(`https://wa.me/26878166787?text=${message}`, "_blank");
    }
  </script>

    <div class="site-signature">
      <span>Built by</span>
      <strong>Magujwa</strong>
    </div>

</body>
</html>
