<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Lindz Beauty — Nail Artistry</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Jost:wght@200;300;400;500&display=swap" rel="stylesheet"/>
<style>
  :root {
    --cream: #FDF6F0;
    --blush: #F2D9DF;
    --mauve: #C9A4C2;
    --plum: #7B4F6E;
    --deep: #2E1A2E;
    --gold: #C8A84B;
    --gold-light: #E8D49A;
    --lavender: #D4C3E2;
    --white: #FFFFFF;
    --text: #3A2535;
    --text-muted: #8A718A;
    --border: rgba(201,164,194,0.25);
  }
  *{margin:0;padding:0;box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{
    font-family:'Jost',sans-serif;
    background:var(--cream);
    color:var(--text);
    overflow-x:hidden;
  }

  /* ── NAV ── */
  nav{
    position:fixed;top:0;left:0;right:0;z-index:100;
    display:flex;align-items:center;justify-content:space-between;
    padding:1.2rem 3rem;
    background:rgba(253,246,240,0.85);
    backdrop-filter:blur(16px);
    border-bottom:1px solid var(--border);
    transition:all .3s;
  }
  .nav-logo{
    font-family:'Cormorant Garamond',serif;
    font-size:1.5rem;font-weight:600;
    color:var(--plum);letter-spacing:0.05em;
  }
  .nav-logo span{color:var(--gold);font-style:italic;}
  .nav-links{display:flex;gap:2.5rem;list-style:none;}
  .nav-links a{
    font-size:0.78rem;letter-spacing:0.15em;text-transform:uppercase;
    color:var(--text-muted);text-decoration:none;font-weight:400;
    transition:color .2s;
  }
  .nav-links a:hover{color:var(--plum);}
  .nav-book-btn{
    background:var(--plum);color:#fff;
    border:none;padding:.65rem 1.6rem;
    font-family:'Jost',sans-serif;font-size:0.75rem;
    letter-spacing:0.15em;text-transform:uppercase;
    cursor:pointer;border-radius:2px;
    transition:background .2s;
  }
  .nav-book-btn:hover{background:var(--deep);}
  .hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;}
  .hamburger span{display:block;width:24px;height:1.5px;background:var(--plum);transition:.3s;}

  /* ── HERO ── */
  .hero{
    min-height:100vh;
    display:grid;grid-template-columns:1fr 1fr;
    padding-top:80px;
    position:relative;overflow:hidden;
  }
  .hero-left{
    display:flex;flex-direction:column;justify-content:center;
    padding:5rem 4rem 5rem 5rem;
    position:relative;z-index:2;
  }
  .hero-eyebrow{
    font-size:0.7rem;letter-spacing:0.25em;text-transform:uppercase;
    color:var(--gold);font-weight:400;margin-bottom:1.5rem;
    display:flex;align-items:center;gap:.75rem;
  }
  .hero-eyebrow::before{content:'';display:block;width:30px;height:1px;background:var(--gold);}
  .hero-title{
    font-family:'Cormorant Garamond',serif;
    font-size:clamp(3rem,5vw,5rem);
    font-weight:300;line-height:1.1;
    color:var(--deep);margin-bottom:1.5rem;
  }
  .hero-title em{font-style:italic;color:var(--plum);}
  .hero-sub{
    font-size:0.9rem;font-weight:300;line-height:1.8;
    color:var(--text-muted);max-width:380px;margin-bottom:3rem;
  }
  .hero-ctas{display:flex;gap:1rem;flex-wrap:wrap;}
  .btn-primary{
    background:var(--plum);color:#fff;
    border:none;padding:.9rem 2.2rem;
    font-family:'Jost',sans-serif;font-size:0.78rem;
    letter-spacing:0.15em;text-transform:uppercase;
    cursor:pointer;border-radius:2px;
    transition:all .25s;
  }
  .btn-primary:hover{background:var(--deep);transform:translateY(-1px);}
  .btn-outline{
    background:transparent;color:var(--plum);
    border:1px solid var(--mauve);padding:.9rem 2.2rem;
    font-family:'Jost',sans-serif;font-size:0.78rem;
    letter-spacing:0.15em;text-transform:uppercase;
    cursor:pointer;border-radius:2px;
    transition:all .25s;
  }
  .btn-outline:hover{background:var(--blush);}
  .hero-stats{
    display:flex;gap:3rem;margin-top:3.5rem;
    padding-top:2rem;border-top:1px solid var(--border);
  }
  .stat-num{
    font-family:'Cormorant Garamond',serif;
    font-size:2rem;font-weight:300;color:var(--plum);
  }
  .stat-label{font-size:0.7rem;color:var(--text-muted);letter-spacing:0.1em;text-transform:uppercase;margin-top:.2rem;}
  .hero-right{
    position:relative;overflow:hidden;
    background:linear-gradient(135deg, #F5D9E8 0%, #E8D4F0 50%, #C8B4D8 100%);
  }
  .hero-img-wrapper{
    width:100%;height:100%;
    display:flex;align-items:center;justify-content:center;
    padding:3rem;
  }
  .hero-img-wrapper img{
    width:100%;height:100%;object-fit:cover;
    border-radius:0;mix-blend-mode:multiply;
    opacity:.9;
  }
  .hero-blob{
    position:absolute;
    border-radius:50%;
    filter:blur(60px);
    opacity:.4;
  }
  .blob-1{width:300px;height:300px;background:#DDB8D0;top:-80px;right:-80px;}
  .blob-2{width:250px;height:250px;background:#C8D4F0;bottom:100px;left:20px;}

  /* ── NOTICE BAR ── */
  .notice-bar{
    background:var(--deep);color:var(--cream);
    padding:1rem 2rem;
    display:flex;align-items:center;justify-content:center;gap:2rem;
    flex-wrap:wrap;
  }
  .notice-item{
    display:flex;align-items:center;gap:.5rem;
    font-size:0.75rem;letter-spacing:0.08em;
  }
  .notice-icon{font-size:1rem;}
  .notice-divider{width:1px;height:20px;background:rgba(255,255,255,.2);}

  /* ── SECTION COMMON ── */
  section{padding:5rem 0;}
  .container{max-width:1200px;margin:0 auto;padding:0 3rem;}
  .section-header{text-align:center;margin-bottom:4rem;}
  .section-tag{
    font-size:0.7rem;letter-spacing:0.25em;text-transform:uppercase;
    color:var(--gold);font-weight:400;margin-bottom:1rem;
    display:flex;align-items:center;justify-content:center;gap:.75rem;
  }
  .section-tag::before,.section-tag::after{
    content:'';display:block;width:30px;height:1px;background:var(--gold);
  }
  .section-title{
    font-family:'Cormorant Garamond',serif;
    font-size:clamp(2rem,4vw,3rem);font-weight:300;
    color:var(--deep);line-height:1.2;
  }
  .section-title em{font-style:italic;color:var(--plum);}
  .section-desc{
    font-size:0.88rem;font-weight:300;color:var(--text-muted);
    line-height:1.9;max-width:500px;margin:.8rem auto 0;
  }

  /* ── SERVICES ── */
  #services{background:var(--white);}
  .services-grid{
    display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));
    gap:1.5px;background:var(--border);
    border:1px solid var(--border);
    border-radius:4px;overflow:hidden;
  }
  .service-card{
    background:var(--white);
    padding:2.2rem;cursor:pointer;
    transition:background .2s;
    position:relative;
  }
  .service-card:hover{background:var(--cream);}
  .service-card.selected{background:var(--deep);}
  .service-card.selected .service-name,
  .service-card.selected .service-desc,
  .service-card.selected .service-duration,
  .service-card.selected .service-price{color:var(--cream)!important;}
  .service-card.selected .service-check{opacity:1;}
  .service-icon{font-size:1.5rem;margin-bottom:1rem;}
  .service-name{
    font-family:'Cormorant Garamond',serif;
    font-size:1.25rem;font-weight:500;color:var(--deep);
    margin-bottom:.4rem;
  }
  .service-desc{font-size:.8rem;color:var(--text-muted);line-height:1.7;margin-bottom:1rem;font-weight:300;}
  .service-footer{display:flex;justify-content:space-between;align-items:flex-end;}
  .service-duration{font-size:.73rem;color:var(--text-muted);letter-spacing:.08em;text-transform:uppercase;}
  .service-price{
    font-family:'Cormorant Garamond',serif;
    font-size:1.4rem;font-weight:500;color:var(--plum);
  }
  .service-check{
    position:absolute;top:1.5rem;right:1.5rem;
    width:22px;height:22px;
    background:var(--gold);border-radius:50%;
    display:flex;align-items:center;justify-content:center;
    opacity:0;transition:.2s;font-size:.75rem;
  }
  .services-actions{
    text-align:center;margin-top:2rem;
  }

  /* ── GALLERY ── */
  #gallery{background:var(--cream);}
  .gallery-grid{
    display:grid;
    grid-template-columns:repeat(3,1fr);
    grid-template-rows:auto;
    gap:12px;
  }
  .gallery-item{
    overflow:hidden;border-radius:4px;cursor:pointer;
    position:relative;background:var(--blush);
  }
  .gallery-item:first-child{grid-column:span 2;grid-row:span 2;}
  .gallery-item img{
    width:100%;height:100%;object-fit:cover;
    transition:transform .5s ease;
    display:block;min-height:200px;
  }
  .gallery-item:hover img{transform:scale(1.04);}
  .gallery-overlay{
    position:absolute;inset:0;
    background:linear-gradient(to top, rgba(46,26,46,.6) 0%,transparent 60%);
    opacity:0;transition:.3s;
    display:flex;align-items:flex-end;padding:1.5rem;
  }
  .gallery-item:hover .gallery-overlay{opacity:1;}
  .gallery-overlay span{
    color:#fff;font-size:.78rem;letter-spacing:.1em;text-transform:uppercase;
  }

  /* ── BOOKING SECTION ── */
  #booking{
    background:linear-gradient(135deg, var(--deep) 0%, #4A2A4A 100%);
    color:var(--cream);
  }
  #booking .section-tag{color:var(--gold-light);}
  #booking .section-tag::before,#booking .section-tag::after{background:var(--gold-light);}
  #booking .section-title{color:var(--cream);}
  #booking .section-desc{color:rgba(253,246,240,.6);}

  .booking-stepper{
    display:flex;align-items:center;justify-content:center;
    gap:0;margin-bottom:3rem;
  }
  .step-item{
    display:flex;flex-direction:column;align-items:center;gap:.5rem;
    position:relative;
  }
  .step-num{
    width:36px;height:36px;border-radius:50%;
    border:1px solid rgba(255,255,255,.3);
    display:flex;align-items:center;justify-content:center;
    font-size:.8rem;color:rgba(255,255,255,.4);
    transition:.3s;
  }
  .step-item.active .step-num{
    background:var(--gold);border-color:var(--gold);
    color:var(--deep);font-weight:500;
  }
  .step-item.done .step-num{
    background:rgba(255,255,255,.15);border-color:rgba(255,255,255,.4);
    color:#fff;
  }
  .step-label{font-size:.68rem;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.4);}
  .step-item.active .step-label{color:var(--gold-light);}
  .step-item.done .step-label{color:rgba(255,255,255,.6);}
  .step-line{width:80px;height:1px;background:rgba(255,255,255,.2);margin-bottom:1.4rem;}

  .booking-panel{
    background:rgba(255,255,255,.05);
    border:1px solid rgba(255,255,255,.1);
    border-radius:8px;padding:3rem;
    max-width:780px;margin:0 auto;
    backdrop-filter:blur(10px);
  }
  .panel-title{
    font-family:'Cormorant Garamond',serif;
    font-size:1.6rem;font-weight:400;color:#fff;
    margin-bottom:.5rem;
  }
  .panel-sub{font-size:.82rem;color:rgba(253,246,240,.5);margin-bottom:2.5rem;font-weight:300;}

  /* Step 1 - service select */
  .booking-services{display:grid;grid-template-columns:1fr 1fr;gap:1rem;}
  .booking-service-item{
    padding:1.2rem 1.4rem;
    background:rgba(255,255,255,.05);
    border:1px solid rgba(255,255,255,.12);
    border-radius:6px;cursor:pointer;
    transition:all .2s;display:flex;align-items:center;justify-content:space-between;
  }
  .booking-service-item:hover{background:rgba(255,255,255,.1);}
  .booking-service-item.selected{
    background:rgba(200,168,75,.15);
    border-color:var(--gold);
  }
  .bsi-name{font-size:.88rem;color:#fff;font-weight:300;}
  .bsi-price{
    font-family:'Cormorant Garamond',serif;
    font-size:1.1rem;color:var(--gold-light);
  }

  /* Step 2 - calendar */
  .calendar-wrap{display:grid;grid-template-columns:1fr 1fr;gap:2rem;}
  .cal-header{
    display:flex;align-items:center;justify-content:space-between;
    margin-bottom:1.2rem;
  }
  .cal-nav{
    background:none;border:1px solid rgba(255,255,255,.2);
    color:#fff;width:32px;height:32px;border-radius:50%;
    cursor:pointer;font-size:.9rem;transition:.2s;
  }
  .cal-nav:hover{background:rgba(255,255,255,.1);}
  .cal-month{font-family:'Cormorant Garamond',serif;font-size:1.1rem;color:#fff;}
  .cal-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:4px;}
  .cal-day-head{font-size:.65rem;text-align:center;color:rgba(255,255,255,.35);letter-spacing:.08em;padding:.3rem 0;}
  .cal-day{
    aspect-ratio:1;display:flex;align-items:center;justify-content:center;
    font-size:.78rem;border-radius:50%;cursor:pointer;
    color:rgba(255,255,255,.6);transition:.2s;
    border:1px solid transparent;
  }
  .cal-day:hover:not(.inactive):not(.past){background:rgba(255,255,255,.1);color:#fff;}
  .cal-day.selected{background:var(--gold);color:var(--deep);font-weight:500;}
  .cal-day.today{border-color:rgba(200,168,75,.5);}
  .cal-day.inactive{color:rgba(255,255,255,.15);cursor:default;}
  .cal-day.past{color:rgba(255,255,255,.15);cursor:default;}
  .cal-day.booked{color:rgba(255,255,255,.2);cursor:not-allowed;text-decoration:line-through;}
  .slots-wrap h4{font-size:.7rem;letter-spacing:.15em;text-transform:uppercase;color:rgba(255,255,255,.5);margin-bottom:1rem;}
  .slots-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:.5rem;}
  .slot{
    padding:.55rem;text-align:center;font-size:.78rem;
    border:1px solid rgba(255,255,255,.15);border-radius:4px;
    cursor:pointer;color:rgba(255,255,255,.7);transition:.2s;
  }
  .slot:hover:not(.slot-taken){background:rgba(255,255,255,.1);color:#fff;}
  .slot.slot-selected{background:var(--gold);border-color:var(--gold);color:var(--deep);font-weight:500;}
  .slot.slot-taken{color:rgba(255,255,255,.2);cursor:not-allowed;background:rgba(0,0,0,.1);}

  /* Step 3 - Form */
  .form-grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem;}
  .form-field{display:flex;flex-direction:column;gap:.4rem;}
  .form-field.full{grid-column:span 2;}
  .form-field label{font-size:.7rem;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.5);}
  .form-field input,.form-field select,.form-field textarea{
    background:rgba(255,255,255,.07);
    border:1px solid rgba(255,255,255,.15);
    border-radius:4px;padding:.75rem 1rem;
    color:#fff;font-family:'Jost',sans-serif;font-size:.88rem;
    transition:.2s;outline:none;
  }
  .form-field input:focus,.form-field select:focus,.form-field textarea:focus{
    border-color:var(--gold);background:rgba(255,255,255,.1);
  }
  .form-field input::placeholder,.form-field textarea::placeholder{color:rgba(255,255,255,.25);}
  .form-field select option{background:var(--deep);}
  .form-field textarea{resize:vertical;min-height:80px;}
  .form-note{
    font-size:.75rem;color:rgba(253,246,240,.45);
    border-left:2px solid var(--gold);padding-left:.75rem;
    line-height:1.6;margin-top:.5rem;
  }

  /* Step 4 - Confirmation */
  .confirm-card{
    background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);
    border-radius:6px;padding:2rem;margin-bottom:1.5rem;
  }
  .confirm-row{
    display:flex;justify-content:space-between;align-items:center;
    padding:.7rem 0;border-bottom:1px solid rgba(255,255,255,.08);
  }
  .confirm-row:last-child{border-bottom:none;}
  .confirm-label{font-size:.75rem;color:rgba(255,255,255,.45);letter-spacing:.08em;text-transform:uppercase;}
  .confirm-val{font-size:.9rem;color:#fff;text-align:right;}
  .payment-methods{
    display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-top:1.5rem;
  }
  .payment-card{
    padding:1.2rem;
    background:rgba(255,255,255,.05);
    border:1px solid rgba(255,255,255,.12);
    border-radius:6px;
  }
  .payment-card h4{font-size:.78rem;color:var(--gold-light);letter-spacing:.08em;text-transform:uppercase;margin-bottom:.5rem;}
  .payment-card p{font-size:.82rem;color:rgba(255,255,255,.7);line-height:1.6;font-weight:300;}
  .deposit-notice{
    background:rgba(200,168,75,.12);
    border:1px solid rgba(200,168,75,.3);
    border-radius:6px;padding:1rem 1.2rem;
    font-size:.8rem;color:var(--gold-light);line-height:1.7;
    margin-bottom:1.5rem;
  }
  .deposit-notice strong{font-weight:500;}
  .step-actions{
    display:flex;justify-content:space-between;align-items:center;
    margin-top:2rem;
  }
  .btn-step-back{
    background:none;border:1px solid rgba(255,255,255,.2);
    color:rgba(255,255,255,.6);padding:.75rem 1.8rem;
    font-family:'Jost',sans-serif;font-size:.78rem;
    letter-spacing:.12em;text-transform:uppercase;
    cursor:pointer;border-radius:2px;transition:.2s;
  }
  .btn-step-back:hover{border-color:rgba(255,255,255,.5);color:#fff;}
  .btn-step-next{
    background:var(--gold);color:var(--deep);
    border:none;padding:.75rem 2.4rem;
    font-family:'Jost',sans-serif;font-size:.78rem;
    letter-spacing:.12em;text-transform:uppercase;
    cursor:pointer;border-radius:2px;font-weight:500;
    transition:.2s;
  }
  .btn-step-next:hover{background:var(--gold-light);}

  /* ── POLICIES ── */
  #policies{background:var(--white);}
  .policies-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:2rem;}
  .policy-card{
    padding:2rem;border:1px solid var(--border);border-radius:4px;
    background:var(--cream);
  }
  .policy-icon{font-size:1.6rem;margin-bottom:1rem;}
  .policy-title{
    font-family:'Cormorant Garamond',serif;font-size:1.2rem;
    color:var(--deep);margin-bottom:.6rem;font-weight:500;
  }
  .policy-text{font-size:.82rem;color:var(--text-muted);line-height:1.8;font-weight:300;}

  /* ── REVIEWS ── */
  #reviews{background:var(--cream);}
  .reviews-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1.5rem;}
  .review-card{
    background:var(--white);
    border:1px solid var(--border);border-radius:4px;
    padding:2rem;
  }
  .review-stars{color:var(--gold);font-size:.9rem;margin-bottom:.8rem;letter-spacing:.1em;}
  .review-text{font-size:.85rem;color:var(--text-muted);line-height:1.8;font-weight:300;font-style:italic;margin-bottom:1.2rem;}
  .review-author{
    display:flex;align-items:center;gap:.8rem;
  }
  .review-avatar{
    width:36px;height:36px;border-radius:50%;
    background:linear-gradient(135deg,var(--mauve),var(--blush));
    display:flex;align-items:center;justify-content:center;
    font-size:.85rem;color:var(--plum);font-weight:500;
  }
  .review-name{font-size:.82rem;color:var(--text);font-weight:400;}
  .review-date{font-size:.72rem;color:var(--text-muted);}

  /* ── CONTACT ── */
  #contact{background:var(--deep);color:var(--cream);}
  .contact-inner{
    display:grid;grid-template-columns:1fr 1fr;gap:5rem;
    align-items:start;
  }
  .contact-left h2{
    font-family:'Cormorant Garamond',serif;
    font-size:clamp(2rem,4vw,2.8rem);font-weight:300;
    color:#fff;line-height:1.2;margin-bottom:1rem;
  }
  .contact-left h2 em{font-style:italic;color:var(--gold-light);}
  .contact-left p{font-size:.85rem;color:rgba(253,246,240,.55);line-height:1.9;font-weight:300;margin-bottom:2rem;}
  .contact-items{display:flex;flex-direction:column;gap:1.2rem;}
  .contact-item{display:flex;align-items:flex-start;gap:1rem;}
  .contact-item-icon{
    width:38px;height:38px;min-width:38px;
    border:1px solid rgba(255,255,255,.15);border-radius:50%;
    display:flex;align-items:center;justify-content:center;
    font-size:.9rem;
  }
  .contact-item-text span{
    display:block;font-size:.68rem;letter-spacing:.12em;text-transform:uppercase;
    color:rgba(255,255,255,.4);margin-bottom:.2rem;
  }
  .contact-item-text p{font-size:.85rem;color:rgba(255,255,255,.8);font-weight:300;line-height:1.5;}
  .whatsapp-btn{
    display:inline-flex;align-items:center;gap:.6rem;
