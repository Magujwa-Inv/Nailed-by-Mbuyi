    <a href="#policies">Policies</a>
    <a href="#contact">Contact</a>
    <a href="https://wa.me/26879466818" target="_blank">WhatsApp</a>
  </div>
</footer>

<script>
// ── DATA ──
const SERVICES = [
  { id:1, icon:'💅', name:'Basic Manicure', desc:'Natural nail shaping, cuticle care, and classic polish application.', duration:'45 min', price:'E XXX' },
  { id:2, icon:'✨', name:'Gel Manicure', desc:'Long-lasting gel polish for a glossy, chip-free finish that lasts 2–3 weeks.', duration:'60 min', price:'E XXX' },
  { id:3, icon:'💎', name:'Acrylic Full Set', desc:'Full acrylic nail extension set with your choice of shape and finish.', duration:'90 min', price:'E XXX' },
  { id:4, icon:'🌸', name:'Acrylic Infill', desc:'Maintenance fill for existing acrylic nails to keep them looking fresh.', duration:'60 min', price:'E XXX' },
  { id:5, icon:'🎨', name:'Nail Art — Simple', desc:'Simple nail art designs: florals, dots, lines, French tips, ombre.', duration:'90 min', price:'E XXX' },
  { id:6, icon:'🖌️', name:'Nail Art — Advanced', desc:'Detailed custom nail art: 3D elements, hand-painted designs, gems.', duration:'120 min', price:'E XXX' },
  { id:7, icon:'💧', name:'Gel Polish Change', desc:'Removal of old gel polish and fresh application of your chosen colour.', duration:'45 min', price:'E XXX' },
  { id:8, icon:'🌿', name:'Nail Removal', desc:'Safe, professional removal of acrylic or gel product.', duration:'30 min', price:'E XXX' },
  { id:9, icon:'🦶', name:'Classic Pedicure', desc:'Foot soak, nail shaping, cuticle care, and polish for pampered feet.', duration:'60 min', price:'E XXX' },
  { id:10, icon:'💜', name:'Gel Pedicure', desc:'Luxurious pedicure with long-lasting gel polish finish.', duration:'75 min', price:'E XXX' },
  { id:11, icon:'🌟', name:'Full Set + Nail Art', desc:'Acrylic full set with custom nail art on all nails. The full experience.', duration:'150 min', price:'E XXX' },
  { id:12, icon:'👑', name:'VIP Pamper Package', desc:'Gel manicure + gel pedicure + nail art accent nails. The works.', duration:'180 min', price:'E XXX' },
];

// Gallery placeholder entries (user will add their own src URLs or base64)
const GALLERY_ITEMS = [
  { label:'Purple Floral Set', src: '' },
  { label:'Burgundy Art Nails', src: '' },
  { label:'Gold & White Florals', src: '' },
  { label:'Custom Design', src: '' },
  { label:'Gel Manicure', src: '' },
];

// ── STATE ──
let selectedService = null;
let selectedDate = null;
let selectedSlot = null;
let currentStep = 1;
let calYear, calMonth;

const today = new Date();
calYear = today.getFullYear();
calMonth = today.getMonth();

// Fake booked slots (for demo)
const bookedSlots = {
  // '2026-04-17': ['09:00','10:00'],
};

const ALL_SLOTS = ['09:00','09:30','10:00','10:30','11:00','11:30','12:00','12:30','13:30','14:00','14:30','15:00','15:30','16:00','16:30'];

// ── RENDER SERVICES MAIN GRID ──
function renderMainServices() {
  const grid = document.getElementById('mainServicesGrid');
  grid.innerHTML = SERVICES.map(s => `
    <div class="service-card" data-id="${s.id}">
      <div class="service-check">✓</div>
      <div class="service-icon">${s.icon}</div>
      <div class="service-name">${s.name}</div>
      <div class="service-desc">${s.desc}</div>
      <div class="service-footer">
        <div class="service-duration">${s.duration}</div>
        <div class="service-price">${s.price}</div>
      </div>
    </div>
  `).join('');
}

// ── RENDER GALLERY ──
function renderGallery() {
  const grid = document.getElementById('galleryGrid');
  const colors = ['#F2D9DF','#D4C3E2','#C9A4C2','#E8D49A','#DDB8D0'];
  const emojis = ['💜','🌸','✨','💎','🎨'];
  grid.innerHTML = GALLERY_ITEMS.map((item, i) => `
    <div class="gallery-item" onclick="openLightbox(${i})">
      ${item.src ? `<img src="${item.src}" alt="${item.label}"/>` : `
        <div style="min-height:220px;background:${colors[i]};display:flex;flex-direction:column;align-items:center;justify-content:center;gap:.5rem;">
          <span style="font-size:3rem">${emojis[i]}</span>
          <span style="font-size:.75rem;color:rgba(46,26,46,.4);letter-spacing:.08em;text-transform:uppercase">${item.label}</span>
          <span style="font-size:.68rem;color:rgba(46,26,46,.3)">Replace with your photo</span>
        </div>
      `}
      <div class="gallery-overlay"><span>${item.label}</span></div>
    </div>
  `).join('');
}

// ── RENDER BOOKING SERVICES ──
function renderBookingServices() {
  const grid = document.getElementById('bookingServiceGrid');
  grid.innerHTML = SERVICES.map(s => `
    <div class="booking-service-item ${selectedService?.id === s.id ? 'selected' : ''}" onclick="selectService(${s.id})">
      <span class="bsi-name">${s.icon} ${s.name}</span>
      <span class="bsi-price">${s.price}</span>
    </div>
  `).join('');
}

function selectService(id) {
  selectedService = SERVICES.find(s => s.id === id);
  renderBookingServices();
}

// ── CALENDAR ──
const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
const DAYS = ['Su','Mo','Tu','We','Th','Fr','Sa'];

function renderCal() {
  document.getElementById('calMonthLabel').textContent = `${MONTHS[calMonth]} ${calYear}`;
  const grid = document.getElementById('calGrid');
  grid.innerHTML = DAYS.map(d => `<div class="cal-day-head">${d}</div>`).join('');

  const first = new Date(calYear, calMonth, 1).getDay();
  const daysInMonth = new Date(calYear, calMonth+1, 0).getDate();

  for(let i=0;i<first;i++) grid.innerHTML += `<div class="cal-day inactive"></div>`;

  for(let d=1; d<=daysInMonth; d++) {
    const date = new Date(calYear, calMonth, d);
    const isSunday = date.getDay() === 0;
    const isPast = date < new Date(today.getFullYear(), today.getMonth(), today.getDate());
    const dateStr = `${calYear}-${String(calMonth+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
    const isToday = d===today.getDate() && calMonth===today.getMonth() && calYear===today.getFullYear();
    const isSelected = selectedDate === dateStr;

    let cls = 'cal-day';
    if(isPast || isSunday) cls += ' past';
    if(isToday) cls += ' today';
    if(isSelected) cls += ' selected';

    const click = (!isPast && !isSunday) ? `onclick="selectDate('${dateStr}')"` : '';
    grid.innerHTML += `<div class="${cls}" ${click}>${d}</div>`;
  }
}

function selectDate(dateStr) {
  selectedDate = dateStr;
  selectedSlot = null;
  renderCal();
  renderSlots();
}

function renderSlots() {
  const grid = document.getElementById('slotsGrid');
  if(!selectedDate) {
    grid.innerHTML = `<p style="color:rgba(255,255,255,.35);font-size:.8rem;grid-column:span 3;">Select a date first</p>`;
    return;
  }
  const booked = bookedSlots[selectedDate] || [];
  grid.innerHTML = ALL_SLOTS.map(t => {
    const taken = booked.includes(t);
    const selected = selectedSlot === t;
    return `<div class="slot ${taken?'slot-taken':''} ${selected?'slot-selected':''}" ${!taken?`onclick="selectSlot('${t}')"`:''}>${t}</div>`;
  }).join('');
}

function selectSlot(t) {
  selectedSlot = t;
  renderSlots();
}

function prevMonth() {
  if(calMonth===0){calMonth=11;calYear--;} else calMonth--;
  renderCal();
}
function nextMonth() {
  if(calMonth===11){calMonth=0;calYear++;} else calMonth++;
  renderCal();
}

// ── STEPPER ──
function goStep(n) {
  // Validate
  if(n===2 && !selectedService){ alert('Please select a service first.'); return; }
  if(n===3 && (!selectedDate || !selectedSlot)){ alert('Please select a date and time slot.'); return; }
  if(n===4){
    const fn = document.getElementById('fname').value.trim();
    const ph = document.getElementById('phone').value.trim();
    if(!fn || !ph){ alert('Please enter your name and phone number.'); return; }
    renderConfirm();
  }

  currentStep = n;
  document.querySelectorAll('.panel-step').forEach(p => p.classList.remove('active'));
  document.getElementById(`step-${n}`).classList.add('active');

  // Update dots
  for(let i=1;i<=4;i++){
    const el = document.getElementById(`step-dot-${i}`);
    el.className = 'step-item';
    if(i < n) el.classList.add('done');
    if(i === n) el.classList.add('active');
  }

  document.getElementById('booking').scrollIntoView({behavior:'smooth'});
}

function renderConfirm() {
  const fn = document.getElementById('fname').value.trim();
  const ln = document.getElementById('lname').value.trim();
  const ph = document.getElementById('phone').value.trim();
  const dateObj = selectedDate ? new Date(selectedDate + 'T00:00:00') : null;
  const dateFormatted = dateObj ? dateObj.toLocaleDateString('en-SZ',{weekday:'long',year:'numeric',month:'long',day:'numeric'}) : '—';

  document.getElementById('confirmCard').innerHTML = `
    <div class="confirm-row"><span class="confirm-label">Service</span><span class="confirm-val">${selectedService?.icon} ${selectedService?.name}</span></div>
    <div class="confirm-row"><span class="confirm-label">Price</span><span class="confirm-val">${selectedService?.price}</span></div>
    <div class="confirm-row"><span class="confirm-label">Duration</span><span class="confirm-val">${selectedService?.duration}</span></div>
    <div class="confirm-row"><span class="confirm-label">Date</span><span class="confirm-val">${dateFormatted}</span></div>
    <div class="confirm-row"><span class="confirm-label">Time</span><span class="confirm-val">${selectedSlot}</span></div>
    <div class="confirm-row"><span class="confirm-label">Name</span><span class="confirm-val">${fn} ${ln}</span></div>
    <div class="confirm-row"><span class="confirm-label">Phone</span><span class="confirm-val">${ph}</span></div>
    <div class="confirm-row"><span class="confirm-label">Commitment Fee</span><span class="confirm-val" style="color:#C8A84B;font-weight:500">E100</span></div>
  `;
}

function submitBooking() {
  // Mark the slot as booked (front-end only for now)
  if(selectedDate && selectedSlot){
    if(!bookedSlots[selectedDate]) bookedSlots[selectedDate] = [];
    bookedSlots[selectedDate].push(selectedSlot);
  }
  document.querySelectorAll('.panel-step').forEach(p => p.classList.remove('active'));
  document.getElementById('step-success').classList.add('active');

  // Build WhatsApp message
  const fn = document.getElementById('fname').value.trim();
  const ln = document.getElementById('lname').value.trim();
  const ph = document.getElementById('phone').value.trim();
  const msg = encodeURIComponent(`Hi Lindz Beauty! 👋\n\nI've just made a booking:\n• Service: ${selectedService?.name}\n• Date: ${selectedDate}\n• Time: ${selectedSlot}\n• Name: ${fn} ${ln}\n• Phone: ${ph}\n\nI'll send my E100 commitment fee now. 💸`);

  // Auto-open WhatsApp
  setTimeout(() => {
    window.open(`https://wa.me/26879466818?text=${msg}`, '_blank');
  }, 800);
}

function resetBooking() {
  selectedService = null; selectedDate = null; selectedSlot = null; currentStep = 1;
  document.querySelectorAll('.panel-step').forEach(p => p.classList.remove('active'));
  document.getElementById('step-1').classList.add('active');
  document.querySelectorAll('.step-item').forEach((el,i) => {
    el.className = 'step-item';
    if(i===0) el.classList.add('active');
  });
  renderBookingServices();
}

// ── GALLERY LIGHTBOX ──
function openLightbox(i) {
  const item = GALLERY_ITEMS[i];
  if(!item.src) return;
  document.getElementById('lightboxImg').src = item.src;
  document.getElementById('lightbox').classList.add('open');
}
function closeLightbox() {
  document.getElementById('lightbox').classList.remove('open');
}

// ── NAV ──
function scrollToBooking() {
  document.getElementById('booking').scrollIntoView({behavior:'smooth'});
}
function openMobileMenu() {
  document.getElementById('mobileMenu').classList.add('open');
}
function closeMobileMenu() {
  document.getElementById('mobileMenu').classList.remove('open');
}

// ── INIT ──
renderMainServices();
renderGallery();
renderBookingServices();
renderCal();
</script>
</body>
</html>
